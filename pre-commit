#!/bin/sh
# ============================================================
# Witness Interactive — Git Pre-Commit Hook
# Blocks commits containing empty or suspiciously small files
#
# INSTALL: Copy this file to .git/hooks/pre-commit
#          Then run: chmod +x .git/hooks/pre-commit
#
# Works on: macOS, Linux, Windows Git Bash / WSL
# ============================================================

# ── CONFIGURATION ────────────────────────────────────────────
# Minimum byte size per file extension.
# Files smaller than this will BLOCK the commit.
MIN_JS=500
MIN_CSS=100
MIN_HTML=200
MIN_MD=50

# Specific file overrides — files that MUST be larger than X bytes.
# Format: "relative/path/from/repo/root:MIN_BYTES"
CRITICAL_FILES="
js/engine/SceneStateMachine.js:5000
js/engine/UIController.js:40000
js/engine/NarratorAudioManager.js:6000
js/engine/AtmosphericEffects.js:8000
js/engine/ConsequenceSystem.js:8000
css/atmospheric-effects.css:1000
js/content/missions/pearl-harbor/japanese-aviator.js:12000
js/content/missions/pearl-harbor/american-sailor.js:12000
js/content/missions/pearl-harbor/american-civilian.js:12000
"

# ── COLOR CODES ──────────────────────────────────────────────
RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
BOLD='\033[1m'
RESET='\033[0m'

# ── STATE ────────────────────────────────────────────────────
BLOCKED=0
WARNINGS=0

echo ""
echo "${BOLD}🔍 Pre-commit: Checking staged files for empty/truncated content...${RESET}"
echo ""

# ── HELPER: get file size portably ───────────────────────────
file_size() {
  if command -v stat >/dev/null 2>&1; then
    # Try GNU stat first (Linux), then BSD stat (macOS)
    stat -c%s "$1" 2>/dev/null || stat -f%z "$1" 2>/dev/null || wc -c < "$1" | tr -d ' '
  else
    wc -c < "$1" | tr -d ' '
  fi
}

# ── PASS 1: Check every staged file by extension ─────────────
# Get list of staged files (added or modified, not deleted)
STAGED=$(git diff --cached --name-only --diff-filter=ACM)

for filepath in $STAGED; do
  # Skip if file doesn't exist on disk (shouldn't happen with ACM filter)
  if [ ! -f "$filepath" ]; then
    continue
  fi

  size=$(file_size "$filepath")
  ext="${filepath##*.}"
  min=0

  case "$ext" in
    js)   min=$MIN_JS ;;
    css)  min=$MIN_CSS ;;
    html) min=$MIN_HTML ;;
    md)   min=$MIN_MD ;;
    *)    continue ;; # Don't check other extensions (images, audio, etc.)
  esac

  if [ "$size" -eq 0 ]; then
    echo "${RED}  ✗ EMPTY FILE: $filepath (0 bytes)${RESET}"
    BLOCKED=$((BLOCKED + 1))
  elif [ "$size" -lt "$min" ]; then
    echo "${YELLOW}  ⚠ SUSPICIOUSLY SMALL: $filepath ($size bytes, expected ≥${min})${RESET}"
    WARNINGS=$((WARNINGS + 1))
  fi
done

# ── PASS 2: Check critical files against specific minimums ────
for entry in $CRITICAL_FILES; do
  # Skip blank lines
  [ -z "$entry" ] && continue

  filepath="${entry%%:*}"
  required="${entry##*:}"

  # Only check if this file is actually staged
  if ! git diff --cached --name-only --diff-filter=ACM | grep -qF "$filepath"; then
    continue
  fi

  if [ ! -f "$filepath" ]; then
    echo "${RED}  ✗ MISSING: $filepath (staged but not found on disk)${RESET}"
    BLOCKED=$((BLOCKED + 1))
    continue
  fi

  size=$(file_size "$filepath")

  if [ "$size" -lt "$required" ]; then
    echo "${RED}  ✗ CRITICAL FILE TOO SMALL: $filepath${RESET}"
    echo "     Got: ${size} bytes — Required: ≥${required} bytes"
    echo "     This file is likely empty or truncated. Re-write from newfiles/ source."
    BLOCKED=$((BLOCKED + 1))
  fi
done

# ── PASS 3: Check that JS files have an export ────────────────
for filepath in $STAGED; do
  [ ! -f "$filepath" ] && continue
  ext="${filepath##*.}"
  [ "$ext" != "js" ] && continue

  size=$(file_size "$filepath")
  [ "$size" -eq 0 ] && continue  # Already caught above

  if ! grep -q "export default" "$filepath" && ! grep -q "export {" "$filepath" && ! grep -q "module.exports" "$filepath"; then
    echo "${YELLOW}  ⚠ NO EXPORT FOUND: $filepath${RESET}"
    echo "     JS file has no export statement. May be incomplete."
    WARNINGS=$((WARNINGS + 1))
  fi
done

# ── RESULT ───────────────────────────────────────────────────
echo ""

if [ "$BLOCKED" -gt 0 ]; then
  echo "${RED}${BOLD}  ✗ COMMIT BLOCKED — $BLOCKED file(s) are empty or critically undersized.${RESET}"
  echo ""
  echo "  Fix the files listed above, then re-stage and commit."
  echo "  To re-stage a single file after fixing:"
  echo "    git add <filepath>"
  echo ""
  echo "  To skip this hook (NOT recommended):"
  echo "    git commit --no-verify"
  echo ""
  exit 1
fi

if [ "$WARNINGS" -gt 0 ]; then
  echo "${YELLOW}${BOLD}  ⚠ $WARNINGS warning(s) — files are small but not empty.${RESET}"
  echo "  Double-check the files above are intentionally short."
  echo "  Committing anyway..."
  echo ""
fi

echo "${GREEN}  ✓ All staged files look good. Proceeding with commit.${RESET}"
echo ""
exit 0
